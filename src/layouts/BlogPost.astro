---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';

interface Props {
	title: string;
	content: string;
	excerpt?: string;
	date: string;
	featuredImage?: {
		node?: {
			sourceUrl?: string;
			altText?: string;
		};
	} | null;
	categories?: Array<{ name: string; slug: string }>;
	tags?: Array<{ name: string; slug: string }>;
	author?: {
		node?: {
			name?: string;
			avatar?: {
				url?: string;
			};
		};
	} | null;
}

const {
	title,
	content,
	excerpt,
	date,
	featuredImage,
	categories = [],
	tags = [],
	author,
} = Astro.props;

const effectiveDescription = excerpt?.replace(/<[^>]+>/g, '')?.substring(0, 160) || title;
const pageTitle = `${title} — SENZANS INDUSTRIAL`;
const authorName = author?.node?.name || 'SENZANS Team';
const authorAvatar = author?.node?.avatar?.url || '';
const imageUrl = featuredImage?.node?.sourceUrl || '';
const imageAlt = featuredImage?.node?.altText || title;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={effectiveDescription} />
		{imageUrl && <meta property="og:image" content={imageUrl} />}
	</head>
	<body>
		<Header />
		<main>
			<article class="blog-post">
				<header class="post-header">
					<div class="post-header-inner">
						{categories.length > 0 && (
							<div class="post-categories">
								{categories.map((cat) => (
									<a href={`/blog?category=${cat.slug}`} class="category-chip">{cat.name}</a>
								))}
							</div>
						)}
						<h1>{title}</h1>
						<div class="post-meta-bar">
							<div class="post-author">
								{authorAvatar ? (
									<img src={authorAvatar} alt={authorName} class="author-avatar" width="36" height="36" />
								) : (
									<div class="author-avatar-placeholder">
										<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
											<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
											<circle cx="12" cy="7" r="4"/>
										</svg>
									</div>
								)}
								<span>{authorName}</span>
							</div>
							<span class="meta-divider">·</span>
							<FormattedDate date={new Date(date)} />
						</div>
					</div>
				</header>
				{imageUrl && (
					<div class="post-hero-image">
						<img src={imageUrl} alt={imageAlt} />
					</div>
				)}
				<div class="post-body">
					<div class="post-content" set:html={content} />
				</div>
				{tags.length > 0 && (
					<footer class="post-footer">
						<div class="post-tags">
							<span class="tags-label">Tags:</span>
							{tags.map((tag) => (
								<a href={`/blog?tag=${tag.slug}`} class="tag-chip">{tag.name}</a>
							))}
						</div>
					</footer>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>
<style>
	.post-header {
		padding: 3.5rem 5% 2rem;
		background: linear-gradient(135deg, #0a2463 0%, #1e3a5f 100%);
		color: #ffffff;
	}
	.post-header-inner {
		max-width: 860px;
		margin: 0 auto;
	}
	.post-categories {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}
	.category-chip {
		display: inline-block;
		font-size: 0.7rem;
		font-weight: 700;
		color: #ffffff;
		background: rgba(255,255,255,0.15);
		padding: 0.3rem 0.75rem;
		border-radius: 50px;
		text-decoration: none;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		transition: background 0.2s ease;
	}
	.category-chip:hover {
		background: rgba(255,255,255,0.28);
	}
	.post-header h1 {
		font-size: 2.2rem;
		font-weight: 800;
		margin: 0 0 1.25rem;
		line-height: 1.25;
		letter-spacing: -0.01em;
	}
	.post-meta-bar {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.82rem;
		color: rgba(255,255,255,0.75);
	}
	.meta-divider {
		color: rgba(255,255,255,0.3);
	}
	.post-author {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.author-avatar {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid rgba(255,255,255,0.3);
	}
	.author-avatar-placeholder {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: rgba(255,255,255,0.1);
		display: flex;
		align-items: center;
		justify-content: center;
		border: 2px solid rgba(255,255,255,0.3);
	}
	.post-hero-image {
		max-width: 940px;
		margin: -1.5rem auto 0;
		padding: 0 5%;
		border-radius: 12px;
		overflow: hidden;
	}
	.post-hero-image img {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 12px;
		box-shadow: 0 12px 45px rgba(10, 36, 99, 0.15);
	}
	.post-body {
		padding: 2.5rem 5% 3rem;
		background-color: #ffffff;
	}
	.post-content {
		max-width: 780px;
		margin: 0 auto;
		font-size: 1.02rem;
		line-height: 1.85;
		color: #334155;
	}
	.post-content :global(h2) {
		font-size: 1.55rem;
		font-weight: 700;
		color: #0a2463;
		margin: 2.5rem 0 1rem;
		line-height: 1.35;
	}
	.post-content :global(h3) {
		font-size: 1.25rem;
		font-weight: 700;
		color: #0a2463;
		margin: 2rem 0 0.75rem;
		line-height: 1.4;
	}
	.post-content :global(h4) {
		font-size: 1.1rem;
		font-weight: 700;
		color: #1e3a5f;
		margin: 1.5rem 0 0.5rem;
	}
	.post-content :global(p) {
		margin: 0 0 1.25rem;
	}
	.post-content :global(a) {
		color: #e63946;
		text-decoration: none;
		border-bottom: 1px solid rgba(230, 57, 70, 0.3);
		transition: border-color 0.2s ease;
	}
	.post-content :global(a:hover) {
		border-color: #e63946;
	}
	.post-content :global(strong) {
		color: #0a2463;
		font-weight: 700;
	}
	.post-content :global(blockquote) {
		border-left: 3px solid #e63946;
		margin: 1.5rem 0;
		padding: 1rem 1.5rem;
		background: #f8fafc;
		border-radius: 0 8px 8px 0;
	}
	.post-content :global(blockquote p) {
		margin: 0;
		color: #475569;
		font-style: italic;
	}
	.post-content :global(ul),
	.post-content :global(ol) {
		margin: 0 0 1.25rem;
		padding-left: 1.5rem;
	}
	.post-content :global(li) {
		margin-bottom: 0.4rem;
	}
	.post-content :global(img) {
		max-width: 100%;
		height: auto;
		border-radius: 8px;
		margin: 1.5rem 0;
	}
	.post-content :global(figure) {
		margin: 1.5rem 0;
	}
	.post-content :global(figcaption) {
		text-align: center;
		font-size: 0.82rem;
		color: #94a3b8;
		margin-top: 0.5rem;
	}
	.post-content :global(pre) {
		background: #f1f5f9;
		padding: 1.25rem;
		border-radius: 8px;
		overflow-x: auto;
		margin: 0 0 1.25rem;
		font-size: 0.88rem;
		line-height: 1.65;
	}
	.post-content :global(code) {
		font-family: 'SF Mono', 'Menlo', 'Monaco', monospace;
		font-size: 0.88em;
		background: #f1f5f9;
		padding: 0.15em 0.4em;
		border-radius: 4px;
	}
	.post-content :global(pre code) {
		background: none;
		padding: 0;
	}
	.post-content :global(hr) {
		border: none;
		border-top: 1px solid #f1f5f9;
		margin: 2rem 0;
	}
	.post-content :global(table) {
		width: 100%;
		border-collapse: collapse;
		margin: 0 0 1.25rem;
		font-size: 0.9rem;
	}
	.post-content :global(th),
	.post-content :global(td) {
		padding: 0.65rem 0.85rem;
		border: 1px solid #e2e8f0;
		text-align: left;
	}
	.post-content :global(th) {
		background: #f8fafc;
		font-weight: 700;
		color: #0a2463;
	}
	.post-footer {
		padding: 0 5% 3.5rem;
		background-color: #ffffff;
	}
	.post-tags {
		max-width: 780px;
		margin: 0 auto;
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.5rem;
		padding-top: 2rem;
		border-top: 1px solid #f1f5f9;
	}
	.tags-label {
		font-size: 0.75rem;
		font-weight: 700;
		color: #94a3b8;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		margin-right: 0.25rem;
	}
	.tag-chip {
		display: inline-block;
		font-size: 0.72rem;
		color: #64748b;
		background: #f8fafc;
		padding: 0.25rem 0.75rem;
		border-radius: 50px;
		text-decoration: none;
		border: 1px solid #e2e8f0;
		transition: all 0.2s ease;
	}
	.tag-chip:hover {
		color: #e63946;
		border-color: #e63946;
		background: #fff;
	}
	@media (max-width: 768px) {
		.post-header {
			padding: 2.5rem 5% 1.5rem;
		}
		.post-header h1 {
			font-size: 1.55rem;
		}
		.post-hero-image {
			margin-top: -1rem;
		}
		.post-hero-image img {
			border-radius: 8px;
		}
		.post-body {
			padding: 2rem 5%;
		}
		.post-content {
			font-size: 0.95rem;
			line-height: 1.75;
		}
		.post-content :global(h2) {
			font-size: 1.3rem;
		}
		.post-content :global(h3) {
			font-size: 1.1rem;
		}
	}
</style>

<section class="features">
	<div class="features-header">
		<h2>Why Choose Us</h2>
		<p class="features-subtitle">Delivering excellence through core competencies</p>
	</div>
	<div class="features-grid">
		<div class="feature-card">
			<div class="feature-icon">
				<svg viewBox="0 0 64 64" width="44" height="44">
					<circle cx="32" cy="32" r="20" fill="rgba(255,255,255,0.06)"/>
					<path d="M32 18v28M22 32h20" stroke="#ffffff" stroke-width="3" stroke-linecap="round"/>
					<circle cx="32" cy="32" r="5" fill="#ffffff"/>
				</svg>
			</div>
			<h3>Precision Manufacturing</h3>
			<p>High-standard production and strict quality control</p>
		</div>
		<div class="feature-divider"></div>
		<div class="feature-card">
			<div class="feature-icon">
				<svg viewBox="0 0 64 64" width="44" height="44">
					<circle cx="32" cy="32" r="20" fill="rgba(255,255,255,0.06)"/>
					<path d="M26 42l6-8 6 6 6-10-8 6-6-4-6 10z" fill="#ffffff"/>
				</svg>
			</div>
			<h3>Innovative Design</h3>
			<p>User-centered design for better experience</p>
		</div>
		<div class="feature-divider"></div>
		<div class="feature-card">
			<div class="feature-icon">
				<svg viewBox="0 0 64 64" width="44" height="44">
					<circle cx="32" cy="32" r="20" fill="rgba(255,255,255,0.06)"/>
					<circle cx="32" cy="32" r="13" stroke="#ffffff" stroke-width="2" fill="none"/>
					<path d="M27 32l4 4 8-7" stroke="#ffffff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
				</svg>
			</div>
			<h3>Reliable Quality</h3>
			<p>Durable materials and long-lasting performance</p>
		</div>
		<div class="feature-divider"></div>
		<div class="feature-card">
			<div class="feature-icon">
				<svg viewBox="0 0 64 64" width="44" height="44">
					<circle cx="32" cy="32" r="20" fill="rgba(255,255,255,0.06)"/>
					<circle cx="32" cy="32" r="9" fill="#ffffff"/>
					<circle cx="32" cy="23" r="4.5" fill="#ffffff"/>
					<circle cx="43" cy="30" r="3.5" fill="#ffffff"/>
					<circle cx="21" cy="30" r="3.5" fill="#ffffff"/>
				</svg>
			</div>
			<h3>Global Service</h3>
			<p>Professional support worldwide</p>
		</div>
	</div>
</section>
<style>
	.features {
		background: linear-gradient(180deg, #0a2463 0%, #0e2d70 100%);
		padding: 6rem 5% 5.5rem;
	}
	.features-header {
		text-align: center;
		margin-bottom: 4rem;
	}
	.features-header h2 {
		font-size: 2.2rem;
		font-weight: 800;
		color: #ffffff;
		margin-bottom: 0.75rem;
		letter-spacing: -0.01em;
	}
	.features-subtitle {
		font-size: 0.9rem;
		color: rgba(255, 255, 255, 0.55);
		margin: 0;
		font-weight: 400;
	}
	.features-grid {
		display: flex;
		align-items: stretch;
		max-width: 1500px;
		margin: 0 auto;
	}
	.feature-card {
		flex: 1;
		text-align: center;
		padding: 2.5rem 1.5rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		cursor: default;
		transition: transform 0.3s ease, background-color 0.3s ease;
		border-radius: 6px;
	}
	.feature-card:hover {
		transform: translateY(-4px);
		background-color: rgba(255, 255, 255, 0.04);
	}
	.feature-divider {
		width: 1px;
		background-color: rgba(255, 255, 255, 0.1);
		margin: 1.5rem 0;
	}
	.feature-icon {
		margin-bottom: 1.5rem;
		transition: transform 0.3s ease;
	}
	.feature-card:hover .feature-icon {
		transform: scale(1.1);
	}
	.feature-card h3 {
		color: #ffffff;
		font-size: 0.95rem;
		font-weight: 700;
		margin-bottom: 0.65rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		line-height: 1.4;
	}
	.feature-card p {
		color: rgba(255, 255, 255, 0.55);
		font-size: 0.8rem;
		line-height: 1.65;
		margin: 0;
		max-width: 200px;
	}
	@media (max-width: 900px) {
		.features {
			padding: 4rem 5% 3.5rem;
		}
		.features-header {
			margin-bottom: 2.5rem;
		}
		.features-header h2 {
			font-size: 1.6rem;
		}
		.features-grid {
			flex-direction: column;
		}
		.feature-divider {
			width: 100%;
			height: 1px;
			margin: 0;
		}
		.feature-card {
			padding: 2rem 1rem;
		}
		.feature-card p {
			max-width: 100%;
		}
	}
</style>

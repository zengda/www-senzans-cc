<style>
	.footer {
		background: linear-gradient(180deg, #0a2463 0%, #081d4f 100%);
		padding: 4.5rem 5% 2rem;
	}
	.footer-container {
		display: flex;
		justify-content: space-between;
		gap: 3rem;
		max-width: 1500px;
		margin: 0 auto;
		padding-bottom: 3rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}
	.footer-left {
		max-width: 260px;
	}
	.footer-logo {
		display: flex;
		align-items: center;
		gap: 0.8rem;
		margin-bottom: 1.1rem;
		text-decoration: none;
	}
	.footer-logo .logo-main {
		font-size: 1.2rem;
		font-weight: 700;
		color: #ffffff;
		display: block;
		line-height: 1;
	}
	.footer-logo .logo-sub {
		font-size: 0.65rem;
		color: rgba(255, 255, 255, 0.55);
		display: block;
		letter-spacing: 0.14em;
		text-transform: uppercase;
	}
	.footer-description {
		font-size: 0.875rem;
		color: #ffffff;
		font-weight: 600;
		margin: 0 0 0.25rem;
	}
	.footer-tagline {
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.45);
		margin: 0;
	}
	.footer-center h4, .footer-contact h4, .footer-right-label {
		color: #ffffff;
		font-size: 0.8rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		margin: 0 0 1.1rem;
	}
	.footer-links {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}
	.footer-links li a {
		color: rgba(255, 255, 255, 0.55);
		font-size: 0.825rem;
		text-decoration: none;
		transition: color 0.25s ease;
	}
	.footer-links li a:hover {
		color: #ffffff;
	}
	.footer-contact {
		max-width: 280px;
	}
	.contact-info {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}
	.contact-info li {
		color: rgba(255, 255, 255, 0.55);
		font-size: 0.825rem;
		line-height: 1.5;
	}
	.contact-label {
		color: rgba(255, 255, 255, 0.35);
		margin-right: 0.3rem;
	}
	.contact-info a {
		color: rgba(255, 255, 255, 0.55);
		text-decoration: none;
		transition: color 0.25s ease;
	}
	.contact-info a:hover {
		color: #ffffff;
	}
	.footer-right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
	}
	.social-links {
		display: flex;
		gap: 0.85rem;
	}
	.social-link {
		color: rgba(255, 255, 255, 0.5);
		transition: color 0.25s ease, transform 0.25s ease;
	}
	.social-link:hover {
		color: #e63946;
		transform: translateY(-2px);
	}
	.social-link:focus-visible {
		outline: 2px solid #e63946;
		outline-offset: 3px;
		border-radius: 2px;
	}
	.footer-bottom {
		max-width: 1500px;
		margin: 0 auto;
		padding-top: 2rem;
	}
	.footer-bottom p {
		color: rgba(255, 255, 255, 0.35);
		font-size: 0.75rem;
		text-align: center;
		margin: 0;
	}
	@media (max-width: 800px) {
		.footer-container {
			flex-direction: column;
			gap: 2.5rem;
		}
		.footer-left {
			max-width: 100%;
		}
		.footer-right {
			align-items: flex-start;
		}
		.social-links {
			gap: 1rem;
		}
	}
</style>

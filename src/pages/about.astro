---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = 'About — SENZANS INDUSTRIAL';
const description = 'Learn about SENZANS INDUSTRIAL, a leading manufacturer of high-quality 3C digital stand solutions. Precision manufacturing, innovative design, and global service.';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<section class="about-hero">
				<div class="about-hero-inner">
					<h1>About SENZANS</h1>
					<p>Building precision stands for the digital world</p>
				</div>
			</section>
			<section class="about-body">
				<div class="about-content">
					<div class="about-image">
						<img src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=modern%20corporate%20headquarters%20building%20blue%20glass%20facade%20professional%20architecture%20photography&image_size=landscape_16_9" alt="SENZANS INDUSTRIAL Headquarters" />
					</div>
					<div class="about-text">
						<h2>Who We Are</h2>
						<p>SENZANS INDUSTRIAL is a leading manufacturer specializing in high-quality 3C digital stand solutions. With years of expertise in precision manufacturing, we design and produce innovative stands for tablets, laptops, and smartphones that meet the demands of modern professionals.</p>
						<p>Our commitment to quality, innovative design, and global service has made us a trusted partner for businesses and consumers worldwide.</p>
						<h2>Our Mission</h2>
						<p>To enhance the digital experience through ergonomic, durable, and beautifully designed stand solutions that improve productivity and well-being in every workspace.</p>
						<h2>Our Values</h2>
						<ul>
							<li><strong>Precision</strong> — Every product is manufactured to the highest standards of accuracy and quality control.</li>
							<li><strong>Innovation</strong> — We continuously push the boundaries of design to create smarter solutions.</li>
							<li><strong>Reliability</strong> — Our products are built to last, providing dependable performance day after day.</li>
							<li><strong>Global Service</strong> — We serve customers around the world with responsive support and timely delivery.</li>
						</ul>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
<style>
	.about-hero {
		background: linear-gradient(135deg, #0a2463 0%, #1e3a5f 100%);
		padding: 4rem 5%;
		text-align: center;
		color: #ffffff;
	}
	.about-hero-inner {
		max-width: 800px;
		margin: 0 auto;
	}
	.about-hero h1 {
		font-size: 2.5rem;
		font-weight: 800;
		margin: 0 0 0.75rem;
		letter-spacing: -0.02em;
	}
	.about-hero p {
		font-size: 1.05rem;
		color: rgba(255,255,255,0.75);
		margin: 0;
	}
	.about-body {
		padding: 3.5rem 5%;
		background-color: #ffffff;
	}
	.about-content {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		max-width: 1200px;
		margin: 0 auto;
		align-items: start;
	}
	.about-image img {
		width: 100%;
		height: auto;
		border-radius: 12px;
		box-shadow: 0 12px 40px rgba(10, 36, 99, 0.1);
	}
	.about-text h2 {
		font-size: 1.4rem;
		font-weight: 700;
		color: #0a2463;
		margin: 0 0 1rem;
		line-height: 1.35;
	}
	.about-text h2:first-child {
		margin-top: 0;
	}
	.about-text p {
		font-size: 0.95rem;
		color: #475569;
		margin: 0 0 1.25rem;
		line-height: 1.75;
	}
	.about-text ul {
		margin: 0 0 1.5rem;
		padding: 0;
		list-style: none;
	}
	.about-text li {
		font-size: 0.95rem;
		color: #475569;
		margin-bottom: 0.75rem;
		padding-left: 1.25rem;
		position: relative;
		line-height: 1.65;
	}
	.about-text li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.55em;
		width: 6px;
		height: 6px;
		background: #e63946;
		border-radius: 50%;
	}
	.about-text strong {
		color: #0a2463;
	}
	@media (max-width: 768px) {
		.about-hero {
			padding: 3rem 5%;
		}
		.about-hero h1 {
			font-size: 1.8rem;
		}
		.about-content {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
		.about-text h2 {
			font-size: 1.2rem;
		}
	}
</style>
